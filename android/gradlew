#!/bin/sh

# Simple wrapper that uses the cached Gradle distribution and Android Studio's bundled JDK.
export JAVA_HOME="/Applications/Android Studio.app/Contents/jbr/Contents/Home"
GRADLE_HOME="/Users/apple/.gradle/wrapper/dists/gradle-8.11.1-bin/bpt9gzteqjrbo1mjrsomdt32c/gradle-8.11.1"
exec "$GRADLE_HOME/bin/gradle" "$@"
